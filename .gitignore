# ==========================================
#  SecurePad - Hybrid .gitignore (Tauri + React + Rust)
# ==========================================

# ------------------------------------------
# 1. Frontend (React / Vite)
# ------------------------------------------
# Dependencies
node_modules/
.pnp/
.pnp.*

# Build artifacts
dist/
dist-ssr/
build/

# Testing
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------
# 2. Backend (Rust / Tauri)
# ------------------------------------------
# Cargo build artifacts and cache
src-tauri/target/

# Si prefieres que cada desarrollador genere su propio lock, descomenta la siguiente línea:
# src-tauri/Cargo.lock

# Tauri temp/build files
src-tauri/gen/android/app/build/
src-tauri/gen/android/.gradle/

# Rust crashes
rust-crash.log

# ------------------------------------------
# 3. Secrets & Credentials (CRITICAL)
# ------------------------------------------
# Environment variables
.env
.env.*
!.env.example


# Android Keystores and sign configs
*.jks
*.keystore
*.key
*.pem
*.pk8
key.properties
keystore.properties
src-tauri/gen/android/keystore.properties
src-tauri/gen/android/key.properties
src-tauri/gen/android/local.properties
keystore.txt    

# ------------------------------------------
# 4. OS & Editor Generated
# ------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
*.DS_Store

# Windows
Thumbs.db
Thumbs.db:encryptable
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Editors / IDEs
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------
# 5. Project Specific / Dev Trash
# ------------------------------------------
# Archivos de la base de datos o vaults locales
*.spd

# Scripts y archivos temporales
temp_*
temp_cr.py
temp_tc.py
temp_git_log.txt

# Global logs
*.log
